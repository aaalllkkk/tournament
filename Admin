<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Tournament Admin</title>

<style>

/* SAME DESIGN */

body{
font-family:Segoe UI;
background:#0f172a;
color:white;
margin:0;
padding:20px;
}

h1{text-align:center;}

.tabs{
display:flex;
gap:10px;
margin-bottom:20px;
justify-content:center;
flex-wrap:wrap;
}

.tab{
background:#1e293b;
padding:10px 18px;
cursor:pointer;
border-radius:6px;
}

.tab.active{
background:#38bdf8;
color:black;
}

.section{
display:none;
background:#1e293b;
padding:20px;
border-radius:10px;
}

.section.active{display:block;}

input,select{
padding:8px;
margin:5px;
border-radius:6px;
border:none;
}

button{
padding:8px 12px;
border:none;
border-radius:6px;
background:#38bdf8;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
margin-top:15px;
}

th,td{
border-bottom:1px solid #334155;
padding:8px;
text-align:center;
}

.teamLogo{
width:30px;
height:30px;
object-fit:cover;
border-radius:4px;
margin-right:6px;
}

</style>
</head>

<body>

<h1>🏆 Tournament Admin</h1>

<div class="tabs">
<div class="tab active" onclick="openTab('teams',event)">Teams</div>
<div class="tab" onclick="openTab('schedule',event)">Matches</div>
</div>

<div id="teams" class="section active">

<h2>Add Team</h2>

<input id="teamName" placeholder="Team Name">
<input type="file" id="teamLogoInput">

<button onclick="addTeam()">Add Team</button>

<ul id="teamList"></ul>

</div>

<div id="schedule" class="section">

<h2>Create Match</h2>

<select id="team1"></select>
<select id="team2"></select>
<input id="date" placeholder="Date">

<button onclick="addMatch()">Add Match</button>

<table>

<thead>
<tr>
<th>Date</th>
<th>Team 1</th>
<th>Score</th>
<th>Team 2</th>
<th>Goals</th>
<th>Yellow</th>
<th>Delete</th>
</tr>
</thead>

<tbody id="matchTable"></tbody>

</table>

</div>


<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getFirestore, collection, addDoc, getDocs, deleteDoc, doc } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

const firebaseConfig={
apiKey:"AIzaSyAmlSol_3Wmfs53A98sEdEm-uSaByGzo28",
authDomain:"tournament-sys.firebaseapp.com",
projectId:"tournament-sys"
}

const app=initializeApp(firebaseConfig)
const db=getFirestore(app)

let teams=[]
let matches=[]

function openTab(id,e){

document.querySelectorAll(".section").forEach(s=>s.classList.remove("active"))
document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"))

document.getElementById(id).classList.add("active")
e.target.classList.add("active")

}

async function loadTeams(){

teams=[]

const querySnapshot=await getDocs(collection(db,"teams"))

querySnapshot.forEach(docSnap=>{
teams.push({id:docSnap.id,...docSnap.data()})
})

renderTeams()

}

async function addTeam(){

let name=document.getElementById("teamName").value.trim()
let file=document.getElementById("teamLogoInput").files[0]

if(name==="")return

let logo=""

if(file){

const reader=new FileReader()

reader.onload=async function(e){

logo=e.target.result

await addDoc(collection(db,"teams"),{
name:name,
logo:logo
})

loadTeams()

}

reader.readAsDataURL(file)

}else{

await addDoc(collection(db,"teams"),{
name:name,
logo:""
})

loadTeams()

}

}

async function deleteTeam(id){

await deleteDoc(doc(db,"teams",id))
loadTeams()

}

function renderTeams(){

let teamList=document.getElementById("teamList")
teamList.innerHTML=""

let select1=document.getElementById("team1")
let select2=document.getElementById("team2")

select1.innerHTML=""
select2.innerHTML=""

teams.forEach(t=>{

let logoHTML=t.logo?`<img class="teamLogo" src="${t.logo}">`:""

teamList.innerHTML+=`
<li>
${logoHTML}${t.name}
<button onclick="deleteTeam('${t.id}')">Delete</button>
</li>
`

select1.innerHTML+=`<option>${t.name}</option>`
select2.innerHTML+=`<option>${t.name}</option>`

})

}

async function addMatch(){

let t1=document.getElementById("team1").value
let t2=document.getElementById("team2").value
let date=document.getElementById("date").value

await addDoc(collection(db,"matches"),{
team1:t1,
team2:t2,
date:date,
score1:0,
score2:0
})

}

window.openTab=openTab
window.addTeam=addTeam
window.deleteTeam=deleteTeam
window.addMatch=addMatch

loadTeams()

</script>

</body>
</html>
